# 本地開發用 Firebase 設定（複製為 .env.local 並填入實際值，勿提交 .env.local）
# 取得方式：Firebase Console → 專案設定 → 一般 → 您的應用程式 (Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 原生 Google 登入（與 google-services.json 的 oauth_client client_id 一致）
VITE_GOOGLE_WEB_CLIENT_ID=

# App Check 開發環境：設為 true 可跳過 App Check 初始化，避免 localhost 出現 reCAPTCHA 401（正式環境無效）
VITE_APP_CHECK_SKIP_IN_DEV=true
# 選填：若要用 Debug Token 通過 App Check（不跳過），從瀏覽器 Console 複製「Firebase App Check debug token」貼於此，並將上列設為 false 或註解
# VITE_APP_CHECK_DEBUG_TOKEN=
