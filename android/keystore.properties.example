# The GOAT Meter — Release 簽章金鑰設定範本
# 使用方式：複製本檔為 keystore.properties，填入實際路徑與密碼後建置 AAB。
# 注意：keystore.properties 與 *.jks / *.keystore 已加入 .gitignore，請勿提交。
#
# storeFile：相對於 android/ 目錄的 keystore 路徑（例如放在 android/ 下則填 release.keystore）
storeFile=release.keystore
storePassword=你的_keystore_密碼
keyAlias=你的_key_別名
keyPassword=你的_key_密碼
