rules_version = '2';
// =============================================================================
// GOAT Meter — 穩定版（Transaction 安全，App Check 關閉）
// =============================================================================
// 設計要點：
// 1. 不在規則內使用 resource（尤其 delete），避免 Transaction 403。
// 2. 寫入條件：isAuthenticated() + hasValidAppCheck()；profiles 僅 isOwner 可寫。
// 3. App Check 關閉：前端有送 token 但 Firebase 後端驗證失敗，暫時僅靠 Auth 防護。
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasValidAppCheck() {
      // 前端有送 token，但 Firebase 後端驗證仍失敗 → 暫時關閉，僅靠 Auth 防護
      return true;
    }

    // 1. User Profile：僅本人可讀寫
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId) && hasValidAppCheck();
    }

    // 2. 投票記錄：登入 + App Check 即可寫入/刪除（不依賴 resource，Transaction 安全）
    match /votes/{voteId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && hasValidAppCheck();
    }

    // 3. 裝置鎖定：同上
    match /device_locks/{deviceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && hasValidAppCheck();
    }

    // 4. 戰區統計：登入 + App Check 可更新，禁止刪除
    match /warzoneStats/{statsId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && hasValidAppCheck();
      allow delete: if false;
    }

    // 5. 專業分析數據
    match /analytics_pro/{cacheKey} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && hasValidAppCheck();
    }
  }
}
