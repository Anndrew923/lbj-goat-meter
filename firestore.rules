rules_version = '2';
// =============================================================================
// GOAT Meter — 穩定版（Transaction 安全，App Check 不強制）
// =============================================================================
// 設計要點：
// 1. 不在規則內使用 resource（尤其 delete），避免 Transaction 403。
// 2. 寫入條件：isAuthenticated() + hasValidAppCheck()；profiles 僅 isOwner 可寫。
// 3. App Check 不強制：先要求「登入 + 帳號/設備綁定」，未通過 App Check 也可寫入。
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. User Profile：僅本人可讀寫
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);
    }

    // 1b. 突發戰區投票存證（僅 Cloud Functions 寫入；前端只讀同步 votedEventIds）
    match /profiles/{userId}/breaking_votes/{eventId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    // 2. 投票記錄：改由 Cloud Functions Admin SDK 寫入，前端一律 read-only
    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // 3. 裝置鎖定：同上，一律由後端控制
    match /device_locks/{deviceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // 4. 戰區統計：改由後端 Transaction 管理統計一致性，前端 read-only
    match /warzoneStats/{statsId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // 5. 專業分析數據
    match /analytics_pro/{cacheKey} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // 6. 突發戰區（global_events）：前端與 App 只讀，所有寫入一律走 Cloud Functions Admin SDK
    match /global_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // 7. 突發戰區子集合 votes：一話題一設備一票，前端不可直接改寫
    match /global_events/{eventId}/votes/{deviceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }
  }
}
