rules_version = '2';
// =============================================================================
// GOAT Meter — 穩定版（Transaction 安全；App Check 稽核於 Console，規則不強制 token）
// =============================================================================
// 設計要點：
// 1. 不在規則內使用 resource（尤其 delete），避免 Transaction 403。
// 2. profiles 僅 isOwner 可寫；votes / warzoneStats 客戶端一律不可寫（僅 Cloud Functions Admin SDK）。
// 3. 方案 B（刪帳撤票）與投票、重置立場之統計異動：僅後端 Callable + Admin Transaction，繞過本規則。
// 4. votes 讀取：僅允許讀取 userId 為本人之文件；漏斗篩選統計改走 Callable getFilteredSentimentSummary。
// 5. global_events 主文件：僅後台管理員（信箱與 src/components/AdminRoute.jsx 之 ADMIN_EMAIL 一致）可建立／刪除；
//    客戶端 update 僅允許 is_active／updatedAt（見 isBreakingGlobalEventAdminOnlyMetaUpdate）；其餘欄位由 Functions 維護。
//    子集合 votes 仍僅 Functions 寫入，與 submitBreakingVote 設計一致。
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 突發戰區後台：與 AdminRoute.jsx 的 ADMIN_EMAIL 同步；勿僅依前端隱藏路由，須由規則強制。
    function isBreakingWarzoneAdmin() {
      return isAuthenticated()
        && request.auth.token.email == 'topaj01@gmail.com';
    }

    // 管理員僅可改 is_active／updatedAt（批次先建後啟、上下架）；票數等仍僅 Functions 寫入。
    function isBreakingGlobalEventAdminOnlyMetaUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['is_active', 'updatedAt']);
    }

    // 1. User Profile：僅本人可讀寫
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);
    }

    // 1b. 突發戰區投票存證（僅 Cloud Functions 寫入；前端只讀同步 votedEventIds）
    match /profiles/{userId}/breaking_votes/{eventId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    // 2. 投票記錄：Admin SDK 寫入；客戶端僅可讀「本人」文件（禁止掃描全集合做統計）
    match /votes/{voteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // 3. 裝置鎖定：同上，一律由後端控制
    match /device_locks/{deviceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // 4. 戰區統計：路線 A（公開只讀）— 大盤資料對所有訪客開放讀取，寫入仍僅後端 Transaction。
    match /warzoneStats/{statsId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // 4b. 隱藏攝影棚 render jobs：
    // - 主文件僅允許建立者（已登入）讀取，避免開放全域 read。
    // - OTT 子文件採「路徑即權杖」策略，僅持有正確 token 的請求可匿名讀取，並要求 token/jobId 欄位一致與未過期。
    match /render_jobs/{jobId} {
      allow read: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow create, update, delete: if false;

      match /tokens/{token} {
        allow get: if resource.data.jobId == jobId
                   && resource.data.renderToken == token
                   && request.time < resource.data.expiresAt;
        allow list, create, update, delete: if false;
      }
    }

    // 5. 專業分析數據：維持已登入可讀，避免公開掃描 analytics cache。
    match /analytics_pro/{cacheKey} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // 6. 突發戰區（global_events）：路線 A（公開只讀）— 內容可公開瀏覽；主文件仍僅管理員可建/刪，update 僅限 is_active+updatedAt。
    match /global_events/{eventId} {
      allow read: if true;
      allow create, delete: if isBreakingWarzoneAdmin();
      allow update: if isBreakingWarzoneAdmin() && isBreakingGlobalEventAdminOnlyMetaUpdate();
    }

    // 7. 突發戰區子集合 votes：隱私收網—避免 deviceId 被枚舉；前端不可直接改寫
    match /global_events/{eventId}/votes/{deviceId} {
      allow read: if false;
      allow create, update, delete: if false;
    }
  }
}
