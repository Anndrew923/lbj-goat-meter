rules_version = '2';
// =============================================================================
// The GOAT Meter — Firestore 安全規則 (2026 修正版)
// =============================================================================
// 設計意圖：
// 1. 確保數據公信力：App Check 封殺腳本，Device Lock 限制一機一票。
// 2. 數據主權：用戶僅能操作本人數據，且禁止刪除他人投票。
// 3. 完整性：嚴格校驗 starId 與投票狀態欄位。
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- 核心安全函式 ---
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function hasValidAppCheck() { return request.appCheck != null; }

    function isAnalyticsProReader() {
      return isAuthenticated() && hasValidAppCheck();
    }

    // 僅允許 analytics_pro 文檔包含白名單欄位，避免臃腫 payload 造成 Reads 成本暴漲
    function isValidAnalyticsProDoc() {
      let d = request.resource.data;
      return d.keys().hasOnly([
        'starId',
        'summary',
        'breakdown',
        'filters',
        'generatedAt',
        'ownerUid'
      ])
      && d.starId == 'lbj';
    }

    // 校驗投票內容（createdAt 支援 serverTimestamp()，規則評估時為 null）
    function isValidVote() {
      let data = request.resource.data;
      let validCreatedAt = data.createdAt == null
        || (data.createdAt is timestamp
            && data.createdAt <= request.time
            && data.createdAt >= request.time - duration.value(60, 's'));
      return data.starId == 'lbj' // 目前僅開放「天選之子」戰區
        && data.status in ['goat', 'fraud', 'king', 'mercenary', 'machine', 'stat_padder'] // 立場白名單（需與 STANCES / FIRESTORE_STATUS_WHITELIST 對齊）
        && data.userId == request.auth.uid
        && validCreatedAt;
    }

    // --- 集合規則 ---

    // 1. 用戶檔案：存取投票狀態與基本資料
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidAppCheck();
      // 允許撤票邏輯：hasVoted 可切換，但必須通過本人驗證與 App Check
      allow update: if isOwner(userId) && hasValidAppCheck();
      allow delete: if isOwner(userId);
    }

    // 2. 投票紀錄：全球戰報數據
    match /votes/{voteId} {
      allow read: if true; // 公開讀取供 Ticker 與地圖使用
      allow create: if isAuthenticated() && hasValidAppCheck() && isValidVote();
      allow update, delete: if false; // 投票後不可修改，撤票由後端 Transaction 刪除（此處可視需求調整）
    }

    // 3. 設備鎖：防止同一設備重複投票
    match /device_locks/{deviceId} {
      allow read: if isAuthenticated();
      // 僅限本人透過 Transaction 寫入或刪除自己的設備鎖
      allow create, update, delete: if isAuthenticated() && hasValidAppCheck();
    }

    // 4. 戰區統計：全球與各戰區彙整數據
    match /warzoneStats/{statsId} {
      allow read: if true;
      allow write: if isAuthenticated() && hasValidAppCheck(); // 僅限已認證 App 更新統計
    }

    // 5. 進階分析數據：僅登入且通過 App Check 的用戶可讀取，並限制欄位白名單
    match /analytics_pro/{docId} {
      allow read: if isAnalyticsProReader();
      allow create, update: if isAnalyticsProReader() && isValidAnalyticsProDoc();
      allow delete: if false;
    }
  }
}
