# Firebase — 請複製為 .env 並填入實際值
# 重要：VITE_FIREBASE_PROJECT_ID 必須與 Firebase Console 的專案 ID 完全一致（差一個字母都會導致 Firestore 離線／無限重載）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Callable 區域：須與後端 functions/index.js 之 FUNCTIONS_REGION / setGlobalOptions.region 一致；留空則為 us-central1
VITE_FIREBASE_FUNCTIONS_REGION=

# 原生 Google 登入（Android/iOS）：Firebase 專案的 Web 用戶端 ID，與 google-services.json 內 oauth_client client_id 一致
VITE_GOOGLE_WEB_CLIENT_ID=

# App Check（公信力）：僅正版 App 請求可進 Firestore，嚴禁進版控，請填入 .env.local
# App Check：reCAPTCHA 網站金鑰（與 Netlify VITE_APP_CHECK_SITE_KEY 一致）
VITE_APP_CHECK_SITE_KEY=
# reCAPTCHA v3 網站金鑰（VITE_RECAPTCHA_SITE_KEY）
# 用於前端取得 token，後端用 RECAPTCHA_SECRET 驗證
VITE_RECAPTCHA_SITE_KEY=
# 開發環境專用：Debug Token，用於本地繞過驗證；瀏覽器 Console 會印出 token，需填入 Firebase Console App Check 白名單
VITE_APP_CHECK_DEBUG_TOKEN=

# 黃金鑰匙（Golden Key）：與後端 firebase functions:config 的 goat.golden_key_secret 必須完全一致，否則會出現 signature-missing / 安全驗證未通過。
# 後端設定：firebase functions:config:set goat.golden_key_secret="你的密鑰字串"
VITE_GOAT_GOLDEN_KEY_SECRET=